                    else:
                        pixels[x, y] = SLATE_GRAY
                else:
                    if tx < 2 and ty < 2:
                        pixels[x, y] = SLATE_GRAY
                    elif tx > 29 and ty > 29:
                        pixels[x, y] = rgb(35, 35, 55)
                    else:
                        pixels[x, y] = DARK_CHARCOAL
                if not is_wall and random.random() < 0.02:
                    pixels[x, y] = MOSS_GREEN
                if random.random() < 0.01:
